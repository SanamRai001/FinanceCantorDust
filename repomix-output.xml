        {isAdmin && <td className="text-right bold">Rs. {fmt(item.total)}</td>}
        <td></td>
      </tr>
    ))}
    {/* Discount subrow */}
    {expandedRows[t._id] && t.line_items?.length > 0 && t.discount > 0 && (
      <tr key={`${t._id}-discount`} className="line-item-subrow">
        <td></td>
        <td></td>
