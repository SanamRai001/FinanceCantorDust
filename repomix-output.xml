  color: var(--text);
  background: var(--surface);
  outline: none;
}

.line-input:focus {
  border-color: var(--blue);
}
/* ── Type toggle ─────────────────────────── */
.type-toggle {
  display: flex;
  gap: 8px;
  margin-bottom: 4px;
}

.type-btn {
  flex: 1;
  padding: 10px;
  border: 1px solid var(--border);
  border-radius: var(--radius);
  background: var(--surface);
  font-size: 13px;
  font-weight: 500;
  color: var(--text-muted);
  transition: all 0.15s;
}

.type-btn--income  { background: var(--green); color: white; border-color: var(--green); }
.type-btn--expense { background: var(--red);   color: white; border-color: var(--red);   }

/* ── Readonly input ──────────────────────── */
.input--readonly {
  background: var(--surface-alt) !important;
  color: var(--text-muted) !important;
  cursor: not-allowed;
}

/* ── Amount colors ───────────────────────── */
td.income  { color: var(--green); }
td.expense { color: var(--red);   }
.text-right { text-align: right; }

/* ── Form group center (for checkbox) ────── */
.form-group--center {
  flex-direction: row;
  align-items: center;
  gap: 10px;
}
/* ── Dashboard ───────────────────────────── */
.dashboard {
  display: flex;
  flex-direction: column;
  gap: 20px;
}

.page-loading {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 200px;
  color: var(--text-muted);
  font-size: 14px;
}

/* ── Chart card ──────────────────────────── */
.chart-card {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 20px;
  box-shadow: var(--shadow);
}

.chart-card__header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20px;
}

.chart-card__title {
  font-size: 15px;
  font-weight: 600;
  color: var(--text);
}


/* ── Chart ───────────────────────────────── */
.chart {
  display: flex;
  align-items: flex-end;
  gap: 16px;
  height: 160px;
  padding-bottom: 28px;
  border-bottom: 1px solid var(--border);
  overflow-x: auto;
}

.chart__empty {
  text-align: center;
  color: var(--text-muted);
  font-size: 13px;
  padding: 40px 0;
}

/* ── Table card header ───────────────────── */
.table-card__header {
  padding: 14px 16px;
  border-bottom: 1px solid var(--border);
}

.table-card__title {
  font-size: 15px;
  font-weight: 600;
  color: var(--text);
}
/* ── Chart filters ───────────────────────── */
.chart-filters {
  display: flex;
  justify-content: space-between;
  align-items: center;
  flex-wrap: wrap;
  gap: 10px;
  margin-bottom: 16px;
}

.period-btns {
  display: flex;
  gap: 4px;
}

.period-btn {
  padding: 5px 12px;
  font-size: 12px;
  font-weight: 500;
  border: 1px solid var(--border);
  border-radius: var(--radius);
  background: var(--surface);
  color: var(--text-muted);
  transition: background 0.15s, color 0.15s, border-color 0.15s;
}

/* FIX: hover only applies when NOT active */
.period-btn:not(.period-btn--active):hover {
  border-color: var(--blue);
  color: var(--blue);
  background: var(--surface);
}

/* FIX: active always stays blue with white text */
.period-btn--active {
  background: var(--blue);
  color: white !important;
  border-color: var(--blue);
}

/* ── Chart ───────────────────────────────── */
.chart__empty {
  text-align: center;
  color: var(--text-muted);
  font-size: 13px;
  padding: 40px 0;
}

/* ── Chart custom range ──────────────────── */
.chart-custom-range {
  display: flex;
  align-items: center;
  gap: 8px;
}

.chart-custom-range input {
  padding: 5px 8px;
  border: 1px solid var(--border);
  border-radius: var(--radius);
  font-size: 12px;
  color: var(--text);
  background: var(--surface);
  outline: none;
}

.chart-custom-range input:focus { border-color: var(--blue); }

.chart-custom-range__sep {
  font-size: 12px;
  color: var(--text-muted);
}

/* ── Table card header ───────────────────── */
.table-card__header {
  padding: 14px 16px;
  border-bottom: 1px solid var(--border);
}

.table-card__title {
  font-size: 15px;
  font-weight: 600;
  color: var(--text);
}
/* ── Reports ─────────────────────────────── */
.reports {
  display: flex;
  flex-direction: column;
  gap: 16px;
}
/* ── Line items expansion ────────────────── */
.items-badge {
  font-size: 11px;
  font-weight: 500;
  color: var(--blue);
  background: rgba(46,94,168,0.1);
  padding: 2px 6px;
  border-radius: 99px;
  white-space: nowrap;
  cursor: pointer;
}

.line-item-subrow td {
  background: #FAF9F6 !important;
  font-size: 12px;
  padding: 8px 16px !important;
  border-bottom: none !important;
  border-top: none !important;
  color: var(--text-muted);
}

.line-item-subrow--total td {
  border-top: 1px dashed var(--border) !important;
  border-bottom: 2px solid var(--border) !important;
  color: var(--text) !important;
  font-weight: 600;
}
/* ── Attachment link ─────────────────────── */
.attachment-link {
  font-size: 12px;
  font-weight: 500;
  color: var(--blue);
  text-decoration: none;
  padding: 2px 8px;
  border: 1px solid var(--blue);
  border-radius: var(--radius);
}
/* ── Report tabs ─────────────────────────── */
.report-tabs {
  display: flex;
  gap: 4px;
  border-bottom: 1px solid var(--border);
  padding-bottom: 0;
}

.report-tab {
  padding: 8px 20px;
  font-size: 13px;
  font-weight: 500;
  color: var(--text-muted);
  background: none;
  border: none;
  border-bottom: 2px solid transparent;
  cursor: pointer;
  transition: all 0.15s;
  margin-bottom: -1px;
}

.report-tab:hover { color: var(--blue); }

.report-tab--active {
  color: var(--blue);
  border-bottom-color: var(--blue);
}

/* ── Category groups ─────────────────────── */
.cat-groups {
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.cat-group {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  overflow: hidden;
  box-shadow: var(--shadow);
}

.cat-group__header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 14px 16px;
  cursor: pointer;
  user-select: none;
  transition: background 0.15s;
}

.cat-group__header:hover { background: var(--surface-alt); }

.cat-group__left {
  display: flex;
  align-items: center;
  gap: 10px;
}

.cat-group__dot {
  width: 10px;
  height: 10px;
  border-radius: 50%;
  flex-shrink: 0;
}

.cat-group__name {
  font-size: 14px;
  font-weight: 600;
  color: var(--text);
}

.cat-group__count {
  font-size: 12px;
  color: var(--text-muted);
  background: var(--surface-alt);
  padding: 2px 8px;
  border-radius: 99px;
}

.cat-group__right {
  display: flex;
  align-items: center;
  gap: 12px;
}

.cat-group__totals {
  display: flex;
  gap: 10px;
  align-items: center;
}

.cat-total {
  font-size: 12px;
  font-weight: 600;
}

.cat-total--income { color: var(--green); }
.cat-total--expense { color: var(--red); }
.cat-total--net { color: var(--text-muted); }

.cat-group__toggle {
  font-size: 11px;
  color: var(--text-muted);
}

.cat-group__body {
  border-top: 1px solid var(--border);
}

.cat-group__body .table th {
  background: var(--bg);
}
/* ── P&L grid ────────────────────────────── */
.pl-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16px;
}
/* ── VAT settlement box ──────────────────── */
.vat-settlement {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 16px 20px;
  box-shadow: var(--shadow);
}

.vat-settlement__row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 8px 0;
  border-bottom: 1px solid var(--border);
  font-size: 13px;
  color: var(--text-muted);
}

.vat-settlement__row:last-child {
  border-bottom: none;
}

.vat-settlement__row--total {
  font-size: 15px;
  font-weight: 600;
  color: var(--text);
  padding-top: 12px;
}
@media (max-width: 768px) {
  .pl-grid { grid-template-columns: 1fr; }
}
.attachment-link:hover {
  background: var(--blue);
  color: white;
}
/* ── Filter bar ──────────────────────────── */
.filter-bar {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 16px;
  display: flex;
  flex-wrap: wrap;
  gap: 12px;
  align-items: flex-end;
  box-shadow: var(--shadow);
}

.filter-bar .form-group {
  flex: 1;
  min-width: 140px;
}

.filter-bar__actions {
  display: flex;
  gap: 8px;
  align-items: flex-end;
  padding-bottom: 1px;
}

/* ── Export bar ──────────────────────────── */
.export-bar {
  display: flex;
  gap: 8px;
  justify-content: flex-end;
}

/* ── Ghost button ────────────────────────── */
.btn--ghost {
  background: var(--surface);
  color: var(--text);
  border: 1px solid var(--border);
}

.btn--ghost:hover {
  background: var(--surface-alt);
}

/* ── Table row colors ────────────────────── */
.row--income  { border-left: 3px solid var(--green); }
.row--expense { border-left: 3px solid var(--red);   }

/* ── Totals row ──────────────────────────── */
.totals-row {
  background: var(--surface-alt);
  border-top: 2px solid var(--border);
}

.totals-row td {
  padding: 12px 16px;
  font-size: 13px;
}

/* ── Voucher type badges ─────────────────── */
.badge--receipt { background: rgba(15,110,86,0.1);  color: var(--green); }
.badge--payment { background: rgba(153,60,29,0.1);  color: var(--red);   }
.badge--journal { background: rgba(46,94,168,0.1);  color: var(--blue);  }
.badge--contra  { background: rgba(133,79,11,0.1);  color: var(--amber); }

/* ── Amount colors ───────────────────────── */
td.income  { color: var(--green); }
td.expense { color: var(--red);   }



/* ── Login page ──────────────────────────── */
.login-page {
  min-height: 100vh;
  background: var(--bg);
  display: flex;
  align-items: center;
  justify-content: center;
}

.login-card {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 40px;
  width: 100%;
  max-width: 400px;
  box-shadow: var(--shadow);
}

.login-card__header {
  text-align: center;
  margin-bottom: 28px;
}

.login-card__title {
  font-size: 22px;
  font-weight: 800;
  color: var(--navy);
  margin-bottom: 6px;
}

.login-card__sub {
  font-size: 13px;
  color: var(--text-muted);
}

.login-form {
  display: flex;
  flex-direction: column;
  gap: 16px;
}

.login-btn {
  width: 100%;
  padding: 10px;
  font-size: 14px;
  margin-top: 4px;
}

.login-btn:disabled {
  opacity: 0.6;
  cursor: not-allowed;
}
/* ══════════════════════════════════════════
   RESPONSIVE
   ══════════════════════════════════════════ */

/* ── Tablet — 1024px and below ───────────── */
@media (max-width: 1024px) {

  .summary-grid {
    grid-template-columns: repeat(2, 1fr);
  }

  .chart-filters {
    flex-direction: column;
    align-items: flex-start;
  }

  .chart-custom-range {
    flex-wrap: wrap;
  }

  .filter-bar {
    flex-direction: column;
  }

  .filter-bar .form-group {
    min-width: 100%;
  }

  .export-bar {
    flex-wrap: wrap;
  }
}

/* ── Mobile — 768px and below ────────────── */
@media (max-width: 768px) {

  /* sidebar becomes a top bar on mobile */
  :root {
    --sidebar-w: 0px;
  }

  .sidebar {
    width: 100%;
    height: 52px;
    position: sticky;
    top: 0;
    left: 0;
    flex-direction: row;
    align-items: center;
    padding: 0;
    z-index: 50;
  }
  .sidebar__logoWrap {
  padding: 4px 12px;
  border-bottom: none;
  border-right: 1px solid rgba(255,255,255,0.1);
  flex-shrink: 0;
  display: flex;
  align-items: center;
  height: 52px;
}

.sidebarLogo {
  height: 36px !important;
  width: auto !important;
  margin: 0 !important;
  display: block !important;
  opacity: 0.95;
}
  .sidebarNav {
    display: flex;
    flex-direction: row;
    padding: 0;
    gap: 0;
    overflow-x: auto;
    flex: 1;
    scrollbar-width: none;
    -ms-overflow-style: none;
  }

  .sidebarNav::-webkit-scrollbar {
    display: none;
  }

  .sidebar_link {
    padding: 16px 14px;
    font-size: 13px;
    white-space: nowrap;
    border-left: none;
  }

  .sidebar_link--active {
    border-left: none;
    border-bottom: 3px solid white;
  }

  .app {
    flex-direction: column;
  }

  .main {
    margin-left: 0;
    width: 100%;
  }

  /* content padding */
  .content {
    padding: 16px;
  }

  /* topbar */
  .topbar {
    padding: 0 16px;
  }

  .topbar__user {
    display: none;
  }

  /* summary cards — stack 2 per row */
  .summary-grid {
    grid-template-columns: repeat(2, 1fr);
    gap: 10px;
  }

  .card__value {
    font-size: 18px;
  }

  /* form — single column */
  .form-grid {
    grid-template-columns: 1fr;
  }

  /* type toggle */
  .type-toggle {
    flex-direction: row;
  }

  /* tables — horizontal scroll */
  .table-card {
    overflow-x: auto;
  }

  .table {
    min-width: 600px;
  }

  /* reports filter bar */
  .filter-bar {
    flex-direction: column;
    gap: 10px;
  }

  .filter-bar .form-group {
    min-width: 100%;
  }

  .filter-bar__actions {
    width: 100%;
    justify-content: flex-end;
  }

  /* export bar */
  .export-bar {
    flex-direction: column;
  }

  .export-bar .btn {
    width: 100%;
    text-align: center;
  }

  /* period buttons — scrollable row */
  .period-btns {
    overflow-x: auto;
    padding-bottom: 4px;
    width: 100%;
  }

  .period-btn {
    white-space: nowrap;
  }

  .chart-custom-range {
    flex-wrap: wrap;
    width: 100%;
  }

  .chart-custom-range input {
    flex: 1;
    min-width: 120px;
  }

  /* page header */
  .page-header {
    flex-wrap: wrap;
    gap: 8px;
  }

  /* login card */
  .login-card {
    margin: 16px;
    padding: 24px;
  }
}

/* ── Small mobile — 480px and below ─────── */
@media (max-width: 480px) {

  .summary-grid {
    grid-template-columns: 1fr;
  }

  .topbar__role {
    display: none;
  }

  .card__value {
    font-size: 16px;
  }

  .chart-card {
    padding: 14px;
  }

  .form-card {
    padding: 14px;
  }

  .table th,
  .table td {
    padding: 8px 10px;
    font-size: 12px;
  }
}

/* ── Accounts ────────────────────────────── */
.accounts {
  display: flex;
  flex-direction: column;
  gap: 16px;
}

.mono {
  font-variant-numeric: tabular-nums;
  font-family: 'Courier New', monospace;
  font-size: 12px;
}

/* ── Opening balances ────────────────────── */
.opening-balances {
  display: flex;
  flex-direction: column;
  gap: 16px;
}
/* ── Journal entries ─────────────────────── */
.journal-entries {
  display: flex;
  flex-direction: column;
  gap: 16px;
}

.journal-lines {
  display: flex;
  flex-direction: column;
  border: 1px solid var(--border);
  border-radius: var(--radius);
  overflow: hidden;
}

.journal-lines__header {
  display: grid;
  grid-template-columns: 2fr 2fr 1fr 1fr 40px;
  gap: 8px;
  padding: 8px 12px;
  background: var(--surface-alt);
  font-size: 11px;
  font-weight: 600;
  color: var(--text-muted);
  text-transform: uppercase;
  letter-spacing: 0.04em;
}

.journal-line {
  display: grid;
  grid-template-columns: 2fr 2fr 1fr 1fr 40px;
  gap: 8px;
  padding: 8px 12px;
  border-top: 1px solid var(--border);
  align-items: center;
}

.journal-line select,
.journal-line input[type="text"],
.journal-line input[type="number"] {
  width: 100%;
  padding: 6px 8px;
  border: 1px solid var(--border);
  border-radius: var(--radius);
  font-size: 13px;
  color: var(--text);
  background: var(--surface);
  outline: none;
}

.journal-line input[type="number"] {
  text-align: right;
}

.journal-line select:focus,
.journal-line input:focus {
  border-color: var(--blue);
}

.journal-lines__totals {
  display: grid;
  grid-template-columns: 2fr 2fr 1fr 1fr 40px;
  gap: 8px;
  padding: 10px 12px;
  background: var(--surface-alt);
  border-top: 2px solid var(--border);
  font-size: 13px;
}
/* ── Export page ─────────────────────────── */
.export-page {
  display: flex;
  flex-direction: column;
  gap: 20px;
}

.export-section {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 20px;
  box-shadow: var(--shadow);
  display: flex;
  flex-direction: column;
  gap: 16px;
}

.export-section__header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
}

.export-section__title {
  font-size: 15px;
  font-weight: 700;
  color: var(--text);
  margin-bottom: 6px;
}

.export-section__desc {
  font-size: 13px;
  color: var(--text-muted);
  line-height: 1.5;
  max-width: 560px;
}

.export-section__filters {
  display: flex;
  gap: 16px;
  flex-wrap: wrap;
  align-items: flex-end;
}

.export-section__filters .form-group {
  flex: 1;
  min-width: 140px;
}

.export-section__what {
  display: flex;
  gap: 8px;
  flex-wrap: wrap;
}

.export-tag {
  font-size: 11px;
  font-weight: 600;
  color: var(--green);
  background: rgba(15,110,86,0.08);
  padding: 3px 10px;
  border-radius: 99px;
}

.export-card {
  flex: 1;
  min-width: 240px;
  background: var(--surface-alt);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 16px;
  display: flex;
  flex-direction: column;
  gap: 10px;
}

.export-card__title {
  font-size: 14px;
  font-weight: 600;
  color: var(--text);
}

.export-card__desc {
  font-size: 12px;
  color: var(--text-muted);
  line-height: 1.5;
}
